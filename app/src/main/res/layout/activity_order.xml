<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/order_layout_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9"
    tools:context=".OrderActivity">

    <!-- 1. TOP MINI NAVBAR (Toolbar) - Stays outside ScrollView, fixed at top -->
<androidx.constraintlayout.widget.ConstraintLayout
android:id="@+id/top_mini_navbar"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_marginTop="32dp"
android:padding="10dp"
app:layout_constraintTop_toTopOf="parent"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent">
<!-- Using parent for start/end for full width effect for background,
     but actual content can still use your guidelines if needed inside -->

<androidx.constraintlayout.widget.Guideline
    android:id="@+id/leftPadding_toolbar"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:layout_constraintGuide_percent="0.08" />

<androidx.constraintlayout.widget.Guideline
    android:id="@+id/rightPadding_toolbar"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:layout_constraintGuide_percent="0.92" />


<ImageButton
    android:id="@+id/back_Button"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:background="@android:color/transparent"
    app:layout_constraintStart_toStartOf="@id/leftPadding_toolbar"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:srcCompat="@drawable/back"
    android:contentDescription="Back button" />

<TextView
    android:id="@+id/text_details"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fontFamily="@font/sora_semibold"
    android:text="Order Summary"
    android:textColor="@color/text_black"
    android:textSize="16sp"
    app:layout_constraintEnd_toEndOf="@id/rightPadding_toolbar"
    app:layout_constraintStart_toStartOf="@id/leftPadding_toolbar"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ScrollView for all content below the toolbar and above the bottom bar -->
<androidx.core.widget.NestedScrollView
android:id="@+id/content_scroll_view"
android:layout_width="0dp"
android:layout_height="0dp"
app:layout_constraintTop_toBottomOf="@+id/top_mini_navbar"
app:layout_constraintBottom_toTopOf="@+id/bottom_bar_container"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent"
android:fillViewport="true">

<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/order_layout_content_wrapper"
android:layout_width="match_parent"
android:layout_height="wrap_content">

<!-- Your existing Guidelines, now inside the scrollable content area -->
<androidx.constraintlayout.widget.Guideline
    android:id="@+id/leftPadding"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:layout_constraintGuide_percent="0.08" />

<androidx.constraintlayout.widget.Guideline
    android:id="@+id/rightPadding"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:layout_constraintGuide_percent="0.92" />


<!-- 2. DELIVER/PICKUP BUTTONS (Now inside ScrollView's ConstraintLayout) -->
<LinearLayout
    android:id="@+id/button_deliver_container"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:background="@drawable/delivery_pick_up_button_bg"
    android:orientation="horizontal"
    android:padding="4dp"
    app:layout_constraintEnd_toStartOf="@+id/rightPadding"
    app:layout_constraintStart_toStartOf="@+id/leftPadding"
    app:layout_constraintTop_toTopOf="parent"> <!-- Top of this inner ConstraintLayout -->
    <!-- ... deliver_button and pickup_button ... -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/deliver_button"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:background="@drawable/delivery_pick_up_button_bg"
        android:fontFamily="@font/sora_semibold"
        android:state_selected="true"
        android:text="@string/deliver"
        android:textAllCaps="false"
        android:textSize="14sp" />
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/pickup_button"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:background="@drawable/delivery_pick_up_button_bg"
        android:fontFamily="@font/sora_semibold"
        android:text="@string/pick_up"
        android:textAllCaps="false"
        android:textSize="14sp" />
</LinearLayout>

<!-- 3. ADDRESS CONTAINER -->
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/address_container"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:layout_constraintEnd_toEndOf="@id/rightPadding"
    app:layout_constraintStart_toStartOf="@+id/leftPadding"
    app:layout_constraintTop_toBottomOf="@+id/button_deliver_container">
    <!-- ... content of address_container ... -->
    <TextView
        android:id="@+id/delivery_address_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/sora_semibold"
        android:text="Delivery Address"
        android:textColor="@color/text_black"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText" />
    <TextView
        android:id="@+id/address_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/sora_semibold"
        android:text="No Address Available"
        android:textColor="@color/black_03"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/delivery_address_header" />
    <TextView
        android:id="@+id/branch_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add yours"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/address_text" />
    <LinearLayout
        android:id="@+id/edit_add_note_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/branch_name"
        app:layout_constraintBottom_toBottomOf="parent" android:paddingBottom="8dp">
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/edit_address_button"
            android:layout_width="0dp"
            android:layout_height="31dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/edit_add_notes_button"
            android:drawableStart="@drawable/edit_square"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingStart="8dp" android:paddingEnd="8dp"
            android:text="Edit Address"
            android:textAllCaps="false"
            android:textSize="12sp" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/add_notes_button"
            android:layout_width="0dp"
            android:layout_height="31dp"
            android:layout_weight="1"
            android:background="@drawable/edit_add_notes_button"
            android:drawableStart="@drawable/document"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingStart="8dp" android:paddingEnd="8dp"
            android:text="Add Note"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

<!-- FrameLayout for order items display area -->
<FrameLayout
    android:id="@+id/order_items_display_area"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    app:layout_constraintTop_toBottomOf="@+id/address_container"
    app:layout_constraintStart_toStartOf="@id/leftPadding"
    app:layout_constraintEnd_toEndOf="@id/rightPadding">
    <!-- ... RecyclerView and product_quantity_container_wrapper as before ... -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_order_summary_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
    android:visibility="gone"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
    tools:visibility="visible"
    tools:listitem="@layout/item_order_summary_product" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/product_quantity_container_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">
        <View
            android:id="@+id/hr"
            android:layout_width="match_parent"
            android:layout_height=".5dp"
            android:background="@color/light_gray_04"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/product_quantity_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@+id/hr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/detail_product_image"
                android:layout_width="65dp"
                android:layout_height="0dp"
                tools:srcCompat="@drawable/caffee_mocha"
                android:scaleType="centerCrop"
                app:layout_constraintDimensionRatio="2:3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:contentDescription="Product image" />
            <TextView
                android:id="@+id/detail_product_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/sora_semibold"
                tools:text="Product Name Very Long To Test Wrapping"
                android:textColor="@color/text_black"
                app:layout_constraintStart_toEndOf="@+id/detail_product_image"
                app:layout_constraintTop_toTopOf="@+id/detail_product_image"
                app:layout_constraintEnd_toStartOf="@+id/quantity_controls_layout"/>
            <TextView
                android:id="@+id/detail_product_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                tools:text="Product Size"
                android:textColor="@color/text_light_grey"
                android:textSize="10sp"
                app:layout_constraintStart_toEndOf="@+id/detail_product_image"
                app:layout_constraintTop_toBottomOf="@+id/detail_product_name"
                app:layout_constraintEnd_toEndOf="@+id/detail_product_name"
                tools:ignore="SmallSp" />
            <LinearLayout
                android:id="@+id/quantity_controls_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageButton
                    android:id="@+id/imageButton3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:srcCompat="@drawable/add"
                    android:contentDescription="Increase quantity" />
                <TextView
                    android:id="@+id/quantity_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:fontFamily="@font/sora_semibold"
                    tools:text="0"
                    android:textColor="@color/text_black"
                    android:textSize="17sp" />
                <ImageButton
                    android:id="@+id/imageButton5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:srcCompat="@drawable/minuscircle"
                    android:contentDescription="Decrease quantity" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@+id/hr1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F9F2ED"
            app:layout_constraintTop_toBottomOf="@+id/product_quantity_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>

<!-- 5. DISCOUNT CONTAINER -->
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/discount_container"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:background="@drawable/discount_background"
    android:padding="8dp"
    app:layout_constraintEnd_toEndOf="@id/rightPadding"
    app:layout_constraintStart_toStartOf="@id/leftPadding"
    app:layout_constraintTop_toBottomOf="@+id/order_items_display_area">
    <!-- ... content of discount_container ... -->
    <ImageButton
        android:id="@+id/imageButton2"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/discount"
        android:contentDescription="Discount icon" />
    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/sora_semibold"
        android:text="Choose a discount"
        android:textColor="@color/black_03"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imageButton2"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageButton
        android:id="@+id/imageButton4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/forward"
        android:contentDescription="Choose discount" />
</androidx.constraintlayout.widget.ConstraintLayout>

<!-- 6. PAYMENT SUMMARY CONTAINER -->
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/summary_container"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:paddingBottom="16dp"
app:layout_constraintEnd_toEndOf="@id/rightPadding"
app:layout_constraintStart_toStartOf="@id/leftPadding"
app:layout_constraintTop_toBottomOf="@id/discount_container"
app:layout_constraintBottom_toBottomOf="parent">
<!-- ... content of summary_container ... -->
<TextView
    android:id="@+id/textView7"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fontFamily="@font/sora_semibold"
    android:text="Payment Summary"
    android:textColor="@color/black_03"
    android:textSize="16dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />
<TextView
    android:id="@+id/textView8"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="Price"
    android:textColor="@color/black_03"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/textView7" />
<TextView
    android:id="@+id/detail_product_price"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fontFamily="@font/sora_semibold"
    tools:text="₱100.00"
    android:textColor="@color/black_03"
    app:layout_constraintBaseline_toBaselineOf="@+id/textView8"
    app:layout_constraintEnd_toEndOf="parent"/>
<TextView
    android:id="@+id/textView10"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="Delivery Fee"
    android:textColor="@color/black_03"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/textView8" />
<TextView
    android:id="@+id/delivery_fee_text"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fontFamily="@font/sora_semibold"
    tools:text="₱20.00"
    android:textColor="@color/black_03"
    app:layout_constraintBaseline_toBaselineOf="@+id/textView10"
    app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 7. BOTTOM TOTAL & PLACE ORDER BUTTON CONTAINER - Stays outside ScrollView, fixed at bottom -->
<androidx.constraintlayout.widget.ConstraintLayout
android:id="@+id/bottom_bar_container"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:background="@color/white"
android:paddingTop="16dp"
android:paddingBottom="16dp"
app:layout_constraintBottom_toBottomOf="parent"
app:layout_constraintEnd_toEndOf="parent"
app:layout_constraintStart_toStartOf="parent">
<!-- ... content of bottom_bar_container ... -->
<!-- ImageView imageView (wallet icon) -->
<ImageView
    android:id="@+id/imageView"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="32dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toTopOf="@+id/button_place_order"
    app:srcCompat="@drawable/wallet"
    android:contentDescription="Payment method icon" />
<TextView
    android:id="@+id/textView9"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:text="Cash/Wallet"
    android:textColor="@color/text_black"
    android:textSize="14sp"
    app:layout_constraintStart_toEndOf="@+id/imageView"
    app:layout_constraintTop_toTopOf="@+id/imageView"
    app:layout_constraintBottom_toTopOf="@+id/total_price_text_currency_prefix"/>
<TextView
    android:id="@+id/total_price_text"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:text="120.00"
    android:textColor="@color/brown_01"
    android:fontFamily="@font/sora_semibold"
    android:textSize="14sp"
    app:layout_constraintStart_toEndOf="@+id/total_price_text_currency_prefix"
    app:layout_constraintTop_toBottomOf="@+id/textView9"
    app:layout_constraintBottom_toBottomOf="@+id/imageView"/>
<TextView
    android:id="@+id/total_price_text_currency_prefix"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    tools:text=""
    android:textColor="@color/brown_01"
    android:fontFamily="@font/sora_semibold"
    android:textSize="14sp"
    app:layout_constraintStart_toEndOf="@+id/imageView"
    app:layout_constraintTop_toBottomOf="@+id/textView9"
    app:layout_constraintBottom_toBottomOf="@+id/imageView"/>
<ImageView
    android:id="@+id/imageView3"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="32dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="@+id/imageView"
    app:layout_constraintBottom_toBottomOf="@+id/total_price_text_currency_prefix"
    app:srcCompat="@drawable/arrow___down_2"
    android:contentDescription="Select payment method" />
<Button
    android:id="@+id/button_place_order"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="32dp"
    android:layout_marginEnd="32dp"
    android:layout_marginTop="16dp"
    android:background="@drawable/button_buy_now"
    android:text="Place Order"
    android:textAllCaps="false"
    app:layout_constraintTop_toBottomOf="@+id/total_price_text_currency_prefix"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>