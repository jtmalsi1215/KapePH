<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/product_detail_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/leftPadding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/rightPadding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.92" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_mini_navbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="@id/rightPadding"
        app:layout_constraintStart_toStartOf="@id/leftPadding"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@android:color/transparent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back" />

        <TextView
            android:id="@+id/text_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sora_semibold"
            android:text="Detail"
            android:textColor="@color/text_black"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@id/heart_button"
            app:layout_constraintStart_toEndOf="@id/back_Button"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/heart_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:src="@drawable/favorite_button_selector"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/frame_layout_img"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:adjustViewBounds="true"
        app:layout_constraintEnd_toStartOf="@+id/checkout_description"
        app:layout_constraintStart_toStartOf="@id/leftPadding"
        app:layout_constraintTop_toBottomOf="@id/top_mini_navbar">

        <ImageView
            android:id="@+id/detail_product_image"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/caffee_mocha" />
    </FrameLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/checkout_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/frame_layout_img"
        app:layout_constraintEnd_toStartOf="@+id/rightPadding"
        app:layout_constraintTop_toTopOf="@+id/frame_layout_img">

        <TextView
            android:id="@+id/detail_product_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sora_semibold"
            android:text="Product Name"
            android:textColor="@color/text_black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/detail_product_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/text_light_grey"
            android:textSize="10sp"
            app:layout_constraintTop_toBottomOf="@+id/detail_product_name" />


    </androidx.constraintlayout.widget.ConstraintLayout>


    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="@id/rating_text"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toEndOf="@+id/frame_layout_img"
        app:layout_constraintTop_toBottomOf="@+id/checkout_description"
        app:srcCompat="@drawable/rating" />


    <TextView
        android:id="@+id/rating_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/sora_semibold"
        android:text="4.8"
        android:textColor="@color/text_black"
        android:textSize="16dp"
        app:layout_constraintStart_toEndOf="@+id/imageView4"
        app:layout_constraintTop_toBottomOf="@+id/checkout_description" />


    <TextView
        android:id="@+id/rating_text_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(320)"
        android:textSize="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/rating_text"
        app:layout_constraintStart_toEndOf="@+id/rating_text" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/img_button_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <ImageButton
        android:id="@+id/fast_deliver_button"
        android:layout_width="59dp"
        android:layout_height="57dp"
        android:layout_marginStart="24dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toTopOf="@+id/text_fast_deliver"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="@+id/leftPadding"
        app:srcCompat="@drawable/fast_delivery" />

    <TextView
        android:id="@+id/text_fast_deliver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:text="Fast Delivery"
        android:textColor="@color/text_light_grey"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/img_button_guideline"
        app:layout_constraintStart_toStartOf="@+id/leftPadding" />

    <ImageButton
        android:id="@+id/quality_beans_button"
        android:layout_width="59dp"
        android:layout_height="57dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="20dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@+id/text_quality_bean"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/more_milk_button"
        app:layout_constraintStart_toEndOf="@+id/fast_deliver_button"
        app:srcCompat="@drawable/quality_bean" />

    <TextView
        android:id="@+id/text_quality_bean"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Quality Beans"
        android:textColor="@color/text_light_grey"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/img_button_guideline"
        app:layout_constraintEnd_toStartOf="@+id/text_more_mlik"
        app:layout_constraintStart_toEndOf="@+id/text_fast_deliver" />

    <ImageButton
        android:id="@+id/more_milk_button"
        android:layout_width="59dp"
        android:layout_height="57dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toTopOf="@+id/text_more_mlik"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/rightPadding"
        app:srcCompat="@drawable/extra_milk" />

    <TextView
        android:id="@+id/text_more_mlik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="Extra Milk"
        android:textColor="@color/text_light_grey"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/img_button_guideline"
        app:layout_constraintEnd_toStartOf="@+id/rightPadding" />

    <View
        android:id="@+id/hr"
        android:layout_width="0dp"
        android:layout_height=".5dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@color/light_gray_04"
        app:layout_constraintEnd_toEndOf="@id/rightPadding"
        app:layout_constraintStart_toStartOf="@id/leftPadding"
        app:layout_constraintTop_toBottomOf="@id/img_button_guideline" />

    <TextView
        android:id="@+id/checkout_product_description_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/sora_semibold"
        android:text="Description"
        android:textColor="@color/text_black"
        android:textSize="16dp"
        app:layout_constraintBottom_toTopOf="@+id/checkout_product_description"
        app:layout_constraintStart_toStartOf="@id/leftPadding" />

    <TextView
        android:id="@+id/checkout_product_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="A cappuccino is an approximately 150 ml (5 oz) beverage, with 25 ml of espresso coffee and 85ml of fresh milk the fo..A cappuccino is an approximately 150 ml (5 oz) beverage, with 25 ml of espresso coffee and 85ml o"
        android:textColor="@color/text_light_grey"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
        app:layout_constraintEnd_toEndOf="@id/rightPadding"
        app:layout_constraintStart_toStartOf="@id/leftPadding"
        app:layout_constraintTop_toBottomOf="@+id/hr" />

    <TextView
        android:id="@+id/text_product_size_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/sora_semibold"
        android:text="Size"
        android:textColor="@color/text_black"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
        app:layout_constraintStart_toStartOf="@id/leftPadding" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toTopOf="@+id/guideline4"
        app:layout_constraintEnd_toEndOf="@id/rightPadding"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@id/leftPadding">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_sm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_product_selector"
            android:fontFamily="@font/sora_semibold"
            android:text="S"
            android:textColor="@color/button_product_selector"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_med"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_product_selector"
            android:fontFamily="@font/sora_semibold"
            android:text="M"
            android:textColor="@color/button_product_selector"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/button_larg"
            app:layout_constraintStart_toEndOf="@+id/button_sm"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_larg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_product_selector"
            android:fontFamily="@font/sora_semibold"
            android:text="L"
            android:textColor="@color/button_product_selector"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent=".89"
        android:orientation="horizontal" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/rightPadding"
        app:layout_constraintStart_toStartOf="@id/leftPadding"
        app:layout_constraintTop_toTopOf="@id/guideline4">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.45" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price"
            android:textColor="@color/text_light_grey"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/detail_product_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sora_semibold"
            android:text="100"
            android:textColor="@color/brown_01"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@+id/currency"
            app:layout_constraintTop_toBottomOf="@id/textView5" />

        <Button
            android:id="@+id/button_buy_now"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/button_buy_now"
            android:text="BUY NOW"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/button_add_to_cart"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/button_add_to_cart"
            android:layout_width="0dp"
            android:textColor="@color/brown_01"
            android:textSize="12sp"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:background="@drawable/button_product_size_pressed"
            android:text="Add to Cart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/detail_product_price"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/currency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/brown_01"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView5" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>